// ============================================
//  Reflect — Prisma Schema
//  Garden metaphor: хүлэмж → цэцэг → яриа → memory tree → цөөрөм
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ============================================
//  USER
// ============================================
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // Clerk auth-ийн ID
  email     String?  @unique
  name      String?
  birthday  String?
  gender    String?
  createdAt DateTime @default(now())

  flowers     Flower[]
  notes       Note[]
  memories    Memory[]
  moodEntries MoodEntry[]
}

// ============================================
//  FLOWER SPECIES — тогтсон цэцгийн төрлүүд
//  Цэцэг бүр өөр зан төлөвтэй (chat persona)
// ============================================
model FlowerSpecies {
  id           String  @id @default(cuid())
  key          String  @unique // "rose", "tulip", "sunflower", "lavender"
  name         String // "Сарнай"
  description  String // товч тайлбар
  color        String // hex өнгө — UI-д ашиглана
  svgPath      String // /public/flowers/rose.svg
  systemPrompt String // энэ цэцгийн chat зан төлөв

  flowers Flower[]
}

// ============================================
//  FLOWER — гацаанд тарьсан нэг цэцэг
//  Нэг цэцэг = нэг яриа
// ============================================
model Flower {
  id        String   @id @default(cuid())
  userId    String
  speciesId String
  plantedAt DateTime @default(now())

  // garden дээрх байрлал
  posX Float
  posY Float

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  species      FlowerSpecies @relation(fields: [speciesId], references: [id])
  conversation Conversation? // цэцэг тарихад яриа үүснэ

  @@index([userId])
}

// ============================================
//  CONVERSATION — нэг цэцэгт хадгалагдсан яриа
// ============================================
model Conversation {
  id        String   @id @default(cuid())
  flowerId  String   @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flower    Flower     @relation(fields: [flowerId], references: [id], onDelete: Cascade)
  messages  Message[]
  memories  Memory[]
  notes     Note[] // ярианаас үүссэн note-ууд
  moodEntry MoodEntry? // яриа дуусахад шидсэн чулуу = нэг mood entry
}

// ============================================
//  MESSAGE — яриа доторх мессеж
// ============================================
model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           Role
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum Role {
  user
  assistant
}

// ============================================
//  MEMORY — ярианаас гаргаж авсан санах ой
//  Memory tree-д харагдана, embedding-ээр хооронд нь холбоно
// ============================================
model Memory {
  id             String                       @id @default(cuid())
  userId         String
  conversationId String
  content        String
  type           MemoryType
  embedding      Unsupported("vector(1536)")? // text-embedding-3-small
  createdAt      DateTime                     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum MemoryType {
  goal // зорилго
  value // үнэт зүйл
  decision // шийдвэр
  lesson // сургамж
  concern // санаа зовнил
}

// ============================================
//  NOTE — хувийн сануулга
//  Шүүгээнд хийх (archived), устгах боломжтой
// ============================================
model Note {
  id             String   @id @default(cuid())
  userId         String
  conversationId String? // яриатай холбоотой бол
  title          String
  body           String
  archived       Boolean  @default(false) // шүүгээнд хийсэн эсэх
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ============================================
//  MOOD ENTRY — яриа дуусахад шидсэн чулуу
//  Нэг яриа → нэг чулуу → нэг mood entry
//  rippleColor: усны долгионы өнгө (сэтгэл санааг илэрхийлнэ)
//  weather: цаг агаарын төлөөлөл (өнгөрсөн өдрүүдийг харуулна)
// ============================================
model MoodEntry {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?  @unique // аль ярианаас үүссэн (чулуугүй шидвэл null)
  mood           String // "calm", "anxious", "happy", "sad", "confused"
  rippleColor    String // hex — долгионы өнгө
  weather        String // "sunny", "rainy", "cloudy", "stormy", "partly_cloudy"
  intensity      Int      @default(3) // 1–5 (долгионы хүч / чулууны хэмжээ)
  note           String?
  date           DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}
